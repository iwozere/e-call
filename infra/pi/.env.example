# Copy to .env and fill in values. Used by docker compose (backend + cloudflared).
# Replace call.example.com with your real hostname (e.g. call.yourdomain.com).

# --- Cloudflare Tunnel ---
# Zero Trust → Networks → Tunnels → your tunnel → Configure → token for `cloudflared`
TUNNEL_TOKEN=

# --- Backend ---
PORT=3001
NODE_ENV=production
ROOM_TTL_MINUTES=1440

# Public URL of the SPA (no trailing slash). Must match Cloudflare route hostname.
# Nginx derives server_name from this host (no separate nginx hostname file).
APP_BASE_URL=https://call.example.com
CORS_ORIGIN=https://call.example.com

# If nginx keeps restarting, set explicitly (must match public hostname, no trailing slash):
# CALL_HOST=call.example.com

# Listen on all interfaces inside the container (required for Docker).
LISTEN_HOST=0.0.0.0
# Respect X-Forwarded-* from nginx / Cloudflare
TRUST_PROXY=true

# P2P only: omit LIVEKIT_* entirely.

# --- Frontend build (used by ./prepare-frontend.sh only; not read by backend) ---
VITE_API_BASE_URL=https://call.example.com
CALL_HOST=call.example.com