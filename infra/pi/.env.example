# Copy to .env in this directory (infra/pi). Used by:
#   - docker compose (backend, nginx; optional cloudflared — see TUNNEL_TOKEN below)
#   - ./prepare-frontend.sh (sources this file so VITE_* are baked into the SPA build)
#
# Replace call.example.com with your real public hostname (e.g. call.e-music.win).

# --- Cloudflare Tunnel (optional in this repo) ---
# Only needed if you run the bundled cloudflared service:
#   docker compose -f docker-compose.p2p.yml --profile tunnel up -d
# If your tunnel lives in another infra project and points at this stack (e.g. HTTP to the Pi’s
# nginx port), leave TUNNEL_TOKEN unset and do not use the `tunnel` profile.
# TUNNEL_TOKEN=

# --- Backend (read by the Node container via compose env_file) ---
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
ROOM_TTL_MINUTES=1440

# Public URL of the SPA (no trailing slash). Must match the hostname users open in the browser.
APP_BASE_URL=https://call.example.com
# Must match the browser origin that loads the SPA (same host as APP_BASE_URL for same-origin API).
CORS_ORIGIN=https://call.example.com

# Listen on all interfaces inside the container (required for Docker).
LISTEN_HOST=0.0.0.0
# Respect X-Forwarded-* from nginx / Cloudflare (required behind the tunnel).
TRUST_PROXY=true

# Optional: salt for SHA-256 hashing of client IPs in audit logs (recommended in production).
# AUDIT_IP_SALT=change-me-long-random-string

# Rate limits (per client IP, sliding window). Defaults match backend if omitted.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_ROOM_CREATE_MAX=30
# RATE_LIMIT_ROOM_JOIN_MAX=120

# P2P stack: omit all three. SFU only: set all three.
# LIVEKIT_URL=wss://your-livekit.example.com
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# If nginx keeps restarting, set explicitly (hostname only, no scheme, no trailing slash):
CALL_HOST=call.example.com

# --- Frontend build (VITE_* — used only when you run ./prepare-frontend.sh or .ps1) ---
# These are compiled into the static JS at build time. After changing any VITE_*, rebuild
# the SPA and refresh infra/pi/html/ before expecting new behavior in the browser.

# Base URL of the API + Socket.IO (no trailing slash).
# For this Pi stack, use the SAME public origin users type in the address bar (HTTPS),
# e.g. https://call.example.com — nginx proxies /api and /socket.io to the backend.
# Wrong value → CORS errors, signaling failures, or calls to the wrong host.
VITE_API_BASE_URL=https://call.example.com

# Default room mode on the home page: p2p | sfu (Pi P2P compose uses p2p).
VITE_DEFAULT_ROOM_MODE=p2p

# TURN relay for WebRTC when STUN-only ICE fails (different NATs, mobile, strict firewalls).
# Set all three, then rebuild the frontend. Example coturn URL (adjust host and transport):
# VITE_TURN_URL=turns:turn.example.com:443?transport=tcp
# VITE_TURN_USERNAME=your-turn-user
# VITE_TURN_PASSWORD=your-turn-credential
#
# VITE_TURN_URL is a single ICE "urls" string (can be turn: or turns:). Prefer turns: on 443 if UDP is blocked.
# Username/password must match what your TURN server expects (coturn static user or time-limited credentials).
