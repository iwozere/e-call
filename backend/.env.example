PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
ROOM_TTL_MINUTES=1440

# Optional: salt for SHA-256 hashing of client IPs in audit logs (recommended in production).
# AUDIT_IP_SALT=

# Rate limits (per client IP, sliding window). Defaults shown.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_ROOM_CREATE_MAX=30
# RATE_LIMIT_ROOM_JOIN_MAX=120

# Docker / reverse proxy (optional)
# LISTEN_HOST=0.0.0.0
# TRUST_PROXY=true

# Optional for P2P-only local dev — omit all three or set all three for SFU (LiveKit).
# LIVEKIT_URL=wss://127.0.0.1:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
